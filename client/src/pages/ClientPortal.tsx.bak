import { useLanguage } from '@/contexts/LanguageContext';
import DashboardLayout from '@/components/DashboardLayout';
import { trpc } from '@/lib/trpc';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Loader2, Plus, MapPin, Calendar, DollarSign, User, Phone, Mail } from 'lucide-react';

export default function ClientPortal() {
  const { t } = useLanguage();
  const { data: missions, isLoading } = trpc.missions.list.useQuery();

  // Filter missions for current client (in real app, would be based on logged-in user)
  const clientMissions = missions?.slice(0, 5) || [];

  const getStatusColor = (status: string) => {
    const colors: Record<string, string> = {
      confirmee: 'bg-green-100 text-green-800',
      en_attente: 'bg-yellow-100 text-yellow-800',
      en_cours: 'bg-blue-100 text-blue-800',
      terminee: 'bg-gray-100 text-gray-800',
      annulee: 'bg-red-100 text-red-800',
    };
    return colors[status] || 'bg-gray-100 text-gray-800';
  };

  return (
    <div className="min-h-screen bg-background">
      {/* Header */}
      <div className="bg-white dark:bg-slate-950 border-b">
        <div className="max-w-7xl mx-auto px-4 py-6">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-3xl font-bold">{t('clientPortal.title')}</h1>
              <p className="text-muted-foreground mt-2">{t('clientPortal.welcome')}</p>
            </div>
            <Button size="lg" className="gap-2">
              <Plus className="h-4 w-4" />
              {t('clientPortal.newBooking')}
            </Button>
          </div>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-4 py-8">
        <div className="space-y-6">
          {/* Quick Stats */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <Card>
              <CardHeader className="pb-3">
                <CardTitle className="text-sm font-medium">{t('clientPortal.upcomingMissions')}</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="text-3xl font-bold">
                  {clientMissions.filter(m => m.status === 'confirmee').length}
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader className="pb-3">
                <CardTitle className="text-sm font-medium">{t('clientPortal.totalSpent')}</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="text-3xl font-bold">€2,450</div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader className="pb-3">
                <CardTitle className="text-sm font-medium">{t('clientPortal.memberSince')}</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="text-lg font-semibold">12 mois</div>
              </CardContent>
            </Card>
          </div>

          {/* My Missions */}
          <div>
            <h2 className="text-2xl font-bold mb-4">{t('clientPortal.myMissions')}</h2>
            
            {isLoading && (
              <div className="flex items-center justify-center py-12">
                <Loader2 className="h-8 w-8 animate-spin text-muted-foreground" />
              </div>
            )}

            {!isLoading && clientMissions.length > 0 && (
              <div className="space-y-4">
                {clientMissions.map((mission) => (
                  <Card key={mission.id} className="hover:shadow-lg transition-shadow">
                    <CardContent className="pt-6">
                      <div className="flex items-start justify-between">
                        <div className="flex-1">
                          <div className="flex items-center gap-3 mb-4">
                            <h3 className="text-lg font-semibold">
                              {mission.origin} → {mission.destination}
                            </h3>
                            <span className={`px-3 py-1 rounded-full text-sm font-medium ${getStatusColor(mission.status || '')}`}>
                              {mission.status}
                            </span>
                          </div>

                          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                            {/* Date */}
                            <div className="flex items-start gap-2">
                              <Calendar className="h-4 w-4 text-muted-foreground mt-1 flex-shrink-0" />
                              <div>
                                <p className="text-sm text-muted-foreground">{t('common.date')}</p>
                                <p className="font-medium">
                                  {new Date(mission.date).toLocaleDateString('fr-FR')}
                                </p>
                              </div>
                            </div>

                            {/* Price */}
                            <div className="flex items-start gap-2">
                              <DollarSign className="h-4 w-4 text-muted-foreground mt-1 flex-shrink-0" />
                              <div>
                                <p className="text-sm text-muted-foreground">{t('common.price')}</p>
                                <p className="font-medium">
                                  {mission.price ? (mission.price / 100).toFixed(2) : '0.00'} €
                                </p>
                              </div>
                            </div>

                            {/* Chauffeur */}
                            {mission.chauffeurId && (
                              <div className="flex items-start gap-2">
                                <User className="h-4 w-4 text-muted-foreground mt-1 flex-shrink-0" />
                                <div>
                                  <p className="text-sm text-muted-foreground">{t('clientPortal.driver')}</p>
                                  <p className="font-medium">{t('clientPortal.driverAssigned')}</p>
                                </div>
                              </div>
                            )}
                          </div>

                          {/* Notes */}
                          {mission.notes && (
                            <div className="mt-4 pt-4 border-t">
                              <p className="text-sm text-muted-foreground mb-1">{t('common.notes')}</p>
                              <p className="text-sm">{mission.notes}</p>
                            </div>
                          )}
                        </div>

                        {/* Actions */}
                        <div className="ml-4 flex flex-col gap-2">
                          <Button size="sm" variant="outline">
                            {t('common.view')}
                          </Button>
                          {mission.status === 'confirmee' && mission.chauffeurId && (
                            <Button size="sm" variant="outline">
                              {t('clientPortal.trackDriver')}
                            </Button>
                          )}
                          <Button size="sm" variant="ghost">
                            {t('clientPortal.invoice')}
                          </Button>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}

            {!isLoading && clientMissions.length === 0 && (
              <Card>
                <CardContent className="flex flex-col items-center justify-center py-12">
                  <MapPin className="h-12 w-12 text-muted-foreground mb-4" />
                  <h3 className="text-lg font-medium">{t('common.noData')}</h3>
                  <p className="text-muted-foreground mt-2">{t('clientPortal.noMissions')}</p>
                  <Button className="mt-4" size="lg">
                    {t('clientPortal.bookNow')}
                  </Button>
                </CardContent>
              </Card>
            )}
          </div>

          {/* Support */}
          <Card className="bg-blue-50 dark:bg-blue-950 border-blue-200">
            <CardContent className="pt-6">
              <div className="flex items-start gap-4">
                <div className="flex-1">
                  <h3 className="font-semibold text-lg mb-2">{t('clientPortal.needHelp')}</h3>
                  <p className="text-sm text-muted-foreground mb-4">
                    {t('clientPortal.supportMessage')}
                  </p>
                  <div className="flex gap-4">
                    <Button variant="outline" className="gap-2">
                      <Phone className="h-4 w-4" />
                      +33 1 23 45 67 89
                    </Button>
                    <Button variant="outline" className="gap-2">
                      <Mail className="h-4 w-4" />
                      support@majestic.fr
                    </Button>
                  </div>
                </div>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  );
}
