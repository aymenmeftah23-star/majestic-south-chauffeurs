# ==============================================
# Majestic South Chauffeurs - Variables d'environnement
# ==============================================

# Environnement
NODE_ENV=production
PORT=3000

# Base de données MySQL (Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=mysql://user:password@host:3306/majestic_south

# Sécurité - CHANGER EN PRODUCTION
SESSION_SECRET=change-me-in-production-very-long-secret-key
JWT_SECRET=change-me-in-production-very-long-jwt-secret

# URLs de l'application
VITE_APP_ID=majestic-south-production
